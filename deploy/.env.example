# InsightFace Access Control API — environment template
# Copy to .env and adjust: cp .env.example .env

# deployment: development | production
#   development — allows skip_liveness (debug); docker-compose.dev.yml sets this
#   production  — forbids skip_liveness; use COMPOSE_MODE=prod or set here
ENVIRONMENT=development

# Container timezone for logs and local timestamps (IANA name, e.g. Asia/Shanghai)
TZ=Asia/Shanghai

# HTTP listen port (Docker Compose maps host:container to this value)
PORT=8123

# Inference: auto | cuda | cpu  (auto = GPU if available, else CPU)
DEVICE=auto

# Docker image deps: gpu | cpu  (compose_up.sh auto-detects; override if needed)
# RUNTIME=gpu

# Docker compose mode: dev | prod  (compose_up.sh reads this when COMPOSE_MODE unset)
# COMPOSE_MODE=dev

# Container platform (compose_up.sh auto-detects from host CPU)
# Mac Apple Silicon → linux/arm64 ; Linux x86 → linux/amd64
# Override only when cross-building for another arch (slower on Mac):
# DOCKER_PLATFORM=linux/amd64

# Paths below are relative to deploy/ (local) or /service (container WORKDIR).
# docker-compose.yml mounts host ./models → /service/models, ./data → /service/data.
DET_MODEL_DIR=./models/detection
RECOG_MODEL_DIR=./models/recog
ANTISPOOF_MODEL_DIR=./models/antispoof
# Default recognition model when multiple .onnx files exist in RECOG_MODEL_DIR
RECOG_MODEL_NAME=glint360k_r100.onnx
# DET_MODEL_NAME=det_10g.onnx

# Gallery persistence (gallery.db + events.db)
DATA_DIR=./data

# 1:N identification threshold (cosine similarity; calibrate on real data)
IDENTIFY_THRESHOLD=0.42

# 1:1 verification threshold (cosine similarity)
VERIFY_THRESHOLD=0.42

# Stranger / intrusion alert on identify (is_stranger + alert fields)
STRANGER_ALERT_ENABLED=true

# Event audit log (SQLite events.db under DATA_DIR)
EVENT_LOG_ENABLED=true
EVENT_LOG_RETENTION_DAYS=90
IDENTIFY_TOP_K=5
MAX_FACES_PER_PERSON=5

# Quality gates
MIN_DET_SCORE=0.5
MIN_FACE_SIZE_PX=80

# Passive RGB liveness (MiniFASNet V1SE + V2 ensemble)
LIVENESS_ENABLED=true
LIVENESS_ON_ENROLL=true
LIVENESS_ON_IDENTIFY=true
LIVENESS_ON_VERIFY=true
LIVENESS_THRESHOLD=0.5
LIVENESS_REQUIRE_BOTH=true

# API key (required in production; unset = no auth, development only)
# API_KEY=your-secret-key
